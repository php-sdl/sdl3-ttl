# ── Zephir build cache ────────────────────────────────────────────────────────
.zephir/

# ── ext/ build artifacts (generated by phpize / make) ────────────────────────
# The Zephir-generated C source files, config.m4, and kernel/ ARE committed so
# that CI and manual `phpize` builds work without requiring Zephir locally.
# Regenerate with `zephir build` if you update .zep sources.
ext/.libs/
ext/autom4te.cache/
ext/build/
ext/modules/
ext/*.lo
ext/*.la
ext/*.dep
ext/Makefile
ext/Makefile.fragments
ext/Makefile.global
ext/Makefile.objects
ext/acinclude.m4
ext/aclocal.m4
ext/configure
ext/configure.ac
ext/config.guess
ext/config.sub
ext/config.nice
ext/config.log
ext/config.status
ext/conftest*
ext/install-sh
ext/libtool
ext/ltmain.sh
ext/missing
ext/mkinstalldirs
ext/run-tests.php
ext/sdl3ttf.dep
ext/sdl3ttf.lo
ext/sdl3ttf.la
ext/stamp-h1
ext/CREDITS
ext/EXPERIMENTAL

# build artifacts inside subdirectories
ext/kernel/*.lo
ext/kernel/*.la
ext/kernel/*.dep
ext/kernel/.libs/
ext/sdl3ttf/**/*.lo
ext/sdl3ttf/**/*.la
ext/sdl3ttf/**/*.dep
ext/sdl3ttf/**/.libs/

# ── Composer ─────────────────────────────────────────────────────────────────
vendor/
composer.lock

# ── IDE stubs (generated by `zephir stubs`) ──────────────────────────────────
# Intentionally committed so IDEs get autocomplete without re-running Zephir.
# Regenerate with `zephir stubs`.

# ── Build logs ────────────────────────────────────────────────────────────────
build.log
compile.log
compile-errors.log

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── JetBrains IDEs ───────────────────────────────────────────────────────────
.idea/
*.iml
